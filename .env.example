LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_MAX_TOKENS=700
LLM_PLANNER_ENABLED=true
LLM_PLANNER_MAX_TOKENS=160
LLM_PLANNER_TIMEOUT_SECONDS=4
QUERY_REWRITE_MAX_TOKENS=180
QUERY_REWRITE_TIMEOUT_SECONDS=4

RACE_REQUEST_TIMEOUT_SECONDS=3
RACE_CACHE_TTL_SECONDS=300

SESSION_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=604800
SESSION_HISTORY_MAX_TURNS=20
MEMORY_RECENT_TURNS=4
MEMORY_CONTEXT_TOKEN_BUDGET=1200
MEMORY_SUMMARY_TOKEN_BUDGET=260
MEMORY_COMPACTION_TOKEN_THRESHOLD=1600
MEMORY_LONG_TERM_ENABLED=true
MEMORY_LONG_TERM_BACKEND=memory
MEMORY_LONG_TERM_TTL_SECONDS=2592000
MEMORY_LONG_TERM_TOP_K=3

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pitwall
POSTGRES_USER=pitwall
POSTGRES_PASSWORD=pitwall
